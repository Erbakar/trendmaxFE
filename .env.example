PORT=3001

PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt

# HashRouter kullanildigi icin URL'de #/odeme-sonuc path'i bulunur.
PAYTR_OK_URL=http://localhost:3000/#/odeme-sonuc?durum=basarili
PAYTR_FAIL_URL=http://localhost:3000/#/odeme-sonuc?durum=basarisiz

# 1 = test, 0 = canli
PAYTR_TEST_MODE=1
PAYTR_DEBUG_ON=1
PAYTR_TIMEOUT_LIMIT=30

# Frontend ayri bir domainde ise API base tanimlayin
VITE_API_BASE_URL=
